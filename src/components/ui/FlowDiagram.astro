---
interface Props {
  source: string[];
  pathA: { label: string; steps: string[] };
  pathB: { label: string; steps: string[] };
  class?: string;
}

const { source, pathA, pathB, class: className = "" } = Astro.props;
---

<div class={`flex flex-col items-center ${className}`}>
  {/* Jalur bersama */}
  <div class="flex flex-col sm:flex-row items-center gap-3 flex-wrap justify-center" data-reveal>
    {source.map((step, i) => (
      <>
        <div class="rounded-lg bg-primary-100 text-primary-900 text-sm font-medium px-4 py-2 text-center">
          {step}
        </div>
        {i < source.length - 1 && (
          <span class="text-primary-500" aria-hidden="true">→</span>
        )}
      </>
    ))}
  </div>

  <div class="w-px h-6 bg-primary-300 my-2" aria-hidden="true"></div>

  {/* Dua jalur paralel */}
  <div class="grid grid-cols-1 md:grid-cols-2 gap-6 w-full max-w-3xl">
    {[pathA, pathB].map((path) => (
      <div
        class="rounded-xl border border-neutral-100 bg-white shadow-sm p-5"
        data-reveal
      >
        <p class="text-xs font-semibold uppercase tracking-wide text-primary-700 mb-3">
          {path.label}
        </p>
        <div class="flex flex-col gap-2">
          {path.steps.map((step, i) => (
            <>
              <div class="rounded-lg bg-neutral-100 text-neutral-900 text-sm px-3 py-2">
                {step}
              </div>
              {i < path.steps.length - 1 && (
                <span class="text-primary-500 text-center" aria-hidden="true">↓</span>
              )}
            </>
          ))}
        </div>
      </div>
    ))}
  </div>
</div>
