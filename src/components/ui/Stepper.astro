---
interface Step {
  title: string;
  description?: string;
  iconSvgPath?: string;
}

interface Props {
  steps: Step[];
  class?: string;
}

const { steps, class: className = "" } = Astro.props;
---

<div class={`grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-${steps.length} gap-8 lg:gap-4 ${className}`}>
  {steps.map((step, i) => (
    <div class="relative flex flex-col items-center text-center" data-reveal>
      <div class="relative flex items-center justify-center w-16 h-16 rounded-full bg-primary-100 text-primary-700 font-heading font-bold text-lg">
        {step.iconSvgPath ? (
          <svg viewBox="0 0 24 24" class="w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
            <path d={step.iconSvgPath} stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        ) : (
          <span>{i + 1}</span>
        )}
        {i < steps.length - 1 && (
          <span
            class="hidden lg:block absolute top-1/2 left-full w-4 h-px bg-primary-300 origin-left"
            aria-hidden="true"
          ></span>
        )}
      </div>
      <h3 class="mt-4 font-heading font-semibold text-lg text-primary-900">
        {step.title}
      </h3>
      {step.description && (
        <p class="mt-1 text-sm text-neutral-500 leading-relaxed">{step.description}</p>
      )}
    </div>
  ))}
</div>
