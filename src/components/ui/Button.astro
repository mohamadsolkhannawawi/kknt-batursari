---
interface Props {
  href?: string;
  variant?: "primary" | "secondary" | "ghost";
  type?: "button" | "submit";
  class?: string;
}

const {
  href,
  variant = "primary",
  type = "button",
  class: className = "",
} = Astro.props;

const base =
  "inline-flex items-center justify-center gap-2 rounded-full font-heading font-semibold text-sm md:text-base px-6 py-3 transition-colors duration-200 focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-2";

const variants = {
  primary: "bg-primary-700 text-white hover:bg-primary-500",
  secondary:
    "border border-primary-700 text-primary-700 bg-transparent hover:bg-primary-100",
  ghost: "text-primary-700 underline underline-offset-4 hover:text-primary-500 px-0 py-0",
};

const classes = `${base} ${variants[variant]} ${className}`;
const Tag = href ? "a" : "button";
---

<Tag class={classes} href={href} type={!href ? type : undefined}>
  <slot />
</Tag>
