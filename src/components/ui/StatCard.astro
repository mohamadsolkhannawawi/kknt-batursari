---
import CountUp from "./CountUp.astro";

interface Props {
  value: string | number;
  label: string;
  animated?: boolean;
  class?: string;
}

const { value, label, animated = true, class: className = "" } = Astro.props;
---

<div class={`rounded-xl bg-white border border-neutral-100 p-4 md:p-5 ${className}`}>
  <p class="font-heading font-bold text-2xl md:text-3xl text-primary-900">
    {animated ? <CountUp value={value} /> : value}
  </p>
  <p class="text-sm text-neutral-500 mt-1">{label}</p>
</div>
