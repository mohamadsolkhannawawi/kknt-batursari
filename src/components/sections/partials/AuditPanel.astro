---
import type { AuditEntry, AuditStat } from "../../../data/auditEnergi";

interface Props {
  stats: AuditStat[];
  entries: AuditEntry[];
}

const { stats, entries } = Astro.props;
---

<div>
  <!-- Grid statistik -->
  <div class="grid grid-cols-2 gap-4 mb-6">
    {stats.map((stat) => (
      <div class="rounded-xl bg-white border border-neutral-100 p-4">
        <p class="font-heading font-bold text-2xl text-primary-900">{stat.value}</p>
        <p class="text-sm text-neutral-500 mt-1">{stat.label}</p>
      </div>
    ))}
  </div>

  <!-- Tabel ringkas (desktop) -->
  <div class="hidden md:block rounded-xl border border-neutral-100 overflow-hidden bg-white">
    <table class="w-full text-sm">
      <thead class="bg-neutral-100 text-left">
        <tr>
          <th class="px-4 py-3 font-semibold text-neutral-900">Lokasi / Kategori</th>
          <th class="px-4 py-3 font-semibold text-neutral-900">Estimasi Konsumsi</th>
          <th class="px-4 py-3 font-semibold text-neutral-900">Rekomendasi Efisiensi</th>
        </tr>
      </thead>
      <tbody>
        {entries.map((entry) => (
          <tr class="border-t border-neutral-100">
            <td class="px-4 py-3 text-neutral-900">{entry.lokasiKategori}</td>
            <td class="px-4 py-3 text-neutral-900">{entry.estimasiKonsumsi}</td>
            <td class="px-4 py-3 text-neutral-500">{entry.rekomendasiEfisiensi}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <!-- Stacked card list (mobile) -->
  <div class="md:hidden flex flex-col gap-3">
    {entries.map((entry) => (
      <div class="rounded-xl border border-neutral-100 bg-white p-4">
        <p class="font-medium text-neutral-900">{entry.lokasiKategori}</p>
        <dl class="mt-2 space-y-1.5 text-sm">
          <div class="flex justify-between gap-3">
            <dt class="text-neutral-500">Estimasi Konsumsi</dt>
            <dd class="text-neutral-900 text-right">{entry.estimasiKonsumsi}</dd>
          </div>
          <div>
            <dt class="text-neutral-500">Rekomendasi</dt>
            <dd class="text-neutral-900 mt-0.5">{entry.rekomendasiEfisiensi}</dd>
          </div>
        </dl>
      </div>
    ))}
  </div>
</div>
