---
import Card from "../ui/Card.astro";
import SectionHeading from "../ui/SectionHeading.astro";
import { programCards } from "../../data/program";
---

<section id="tentang" class="bg-neutral-100">
  <div class="container-site section-spacing">
    <SectionHeading
      title="Tentang Program KKN-Tematik ESDM"
      subtitle="Program ini dikerjakan oleh dua kelompok kerja yang saling melengkapi: pemetaan teknis di lapangan, dan sosialisasi ke warga."
    />

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      {programCards.map((card) => (
        <Card hoverable data-reveal>
          <div class="w-12 h-12 rounded-full bg-primary-100 text-primary-700 flex items-center justify-center mb-4">
            <svg viewBox="0 0 24 24" class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
              <path d={card.iconSvgPath} stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </div>
          <h3 class="text-lg md:text-xl font-semibold text-primary-900">{card.title}</h3>
          <ul class="mt-3 space-y-2">
            {card.bullets.map((bullet) => (
              <li class="flex items-start gap-2 text-base leading-relaxed text-neutral-900/80">
                <svg viewBox="0 0 24 24" class="w-5 h-5 shrink-0 text-primary-500 mt-0.5" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="m5 13 4 4L19 7" />
                </svg>
                <span>{bullet}</span>
              </li>
            ))}
          </ul>
        </Card>
      ))}
    </div>
  </div>
</section>
