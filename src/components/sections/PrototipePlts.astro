---
import Badge from "../ui/Badge.astro";
import FlowDiagram from "../ui/FlowDiagram.astro";
import {
  pltsStatus,
  pltsFlow,
  pltsSpesifikasi,
  pltsCatatanMekanisme,
  pltsVisual,
} from "../../data/prototipePlts";
---

<section id="pltsa" class="bg-primary-100/60 py-16 md:py-24">
  <div class="container-site max-w-6xl mx-auto px-4">
    
    <!-- HEADER -->
    <div class="max-w-3xl mb-12" data-reveal>
      <div class="flex items-center gap-3 mb-3">
        <Badge variant="solid">{pltsStatus.badge}</Badge>
      </div>
      <h2 class="text-3xl md:text-4xl font-bold text-primary-900 leading-tight">
        {pltsStatus.title}
      </h2>
      <p class="text-base md:text-lg text-neutral-700 mt-3 leading-relaxed">
        {pltsStatus.deskripsi}
      </p>
    </div>

    <!-- MAIN GRID: FOTO (KIRI) + PENJELASAN & HIGHLIGHTS (KANAN) -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center mb-16" data-reveal>
      <!-- Gambar di Kiri (5 / 12) -->
      <div class="lg:col-span-5">
        <div class="rounded-2xl overflow-hidden border border-neutral-200/80 shadow-md bg-white">
          <img
            src={pltsVisual.src}
            alt={pltsVisual.alt}
            width="800"
            height="600"
            loading="lazy"
            class="w-full h-72 md:h-96 object-cover"
          />
        </div>
      </div>

      <!-- Penjelasan Naratif di Kanan (7 / 12) -->
      <div class="lg:col-span-7 space-y-5">
        <div class="bg-white p-6 md:p-8 rounded-2xl border border-neutral-200/80 shadow-sm">
          <p class="text-base md:text-lg text-neutral-800 leading-relaxed">
            Melalui peragaan prototipe PLTSa ini, siswa diajak untuk memahami pentingnya <strong class="text-primary-900 font-semibold">pengelolaan sampah berbasis 3R</strong> di lingkungan sekolah. 
          </p>
          <p class="text-base text-neutral-600 leading-relaxed mt-3">
            Program ini memberikan demonstrasi visual langsung bagaimana limbah sampah dapat dikonversi menjadi <strong class="text-primary-900 font-semibold">sumber energi listrik terbarukan</strong>, sekaligus memantik kepedulian lingkungan dan minat inovasi teknologi sejak dini.
          </p>

          <!-- Poin Ringkas Pendukung -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mt-6 pt-6 border-t border-neutral-100">
            <div class="flex items-start gap-3">
              <span class="p-2 rounded-lg bg-emerald-50 text-emerald-700 shrink-0">
                <i class="fas fa-recycle text-base"></i>
              </span>
              <div>
                <h4 class="text-sm font-semibold text-neutral-900">Edukasi 3R</h4>
                <p class="text-xs text-neutral-500 mt-0.5">Pengolahan & pemilahan limbah sekolah</p>
              </div>
            </div>
            <div class="flex items-start gap-3">
              <span class="p-2 rounded-lg bg-emerald-50 text-emerald-700 shrink-0">
                <i class="fas fa-bolt text-base"></i>
              </span>
              <div>
                <h4 class="text-sm font-semibold text-neutral-900">Konversi Listrik</h4>
                <p class="text-xs text-neutral-500 mt-0.5">Demonstrasi EBT interaktif</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ALUR KERJA (FLOW DIAGRAM) -->
    <div class="bg-white rounded-2xl border border-neutral-200/80 p-6 md:p-8 mb-8 shadow-sm" data-reveal>
      <h3 class="font-heading font-semibold text-lg text-primary-900 mb-6">Alur Kerja & Konversi Prototipe</h3>
      <FlowDiagram source={pltsFlow.source} pathA={pltsFlow.pathA} pathB={pltsFlow.pathB} />
    </div>

    <!-- SPESIFIKASI PROGRAM -->
    <div class="bg-white rounded-2xl border border-neutral-200/80 p-6 md:p-8 shadow-sm" data-reveal>
      <h3 class="font-heading font-semibold text-lg text-primary-900 mb-4">Informasi & Spesifikasi Program</h3>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-6">
        {pltsSpesifikasi.map((spek) => (
          <div class="rounded-xl bg-neutral-50 border border-neutral-100 px-4 py-3">
            <p class="text-xs text-neutral-500 font-medium">{spek.label}</p>
            <p class="font-semibold text-neutral-900 mt-0.5 text-sm">{spek.value}</p>
          </div>
        ))}
      </div>
      <p class="text-xs md:text-sm text-neutral-500 border-t border-neutral-100 pt-4 italic">
        {pltsCatatanMekanisme}
      </p>
    </div>

  </div>
</section>