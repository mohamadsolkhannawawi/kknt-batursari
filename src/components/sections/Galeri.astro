---
import SectionHeading from "../ui/SectionHeading.astro";
import { galeriList } from "../../data/galeri";

const serializedGaleri = JSON.stringify(galeriList);
---

<section id="galeri" class="bg-neutral-100">
  <div class="container-site section-spacing">
    <SectionHeading
      title="Dokumentasi Kegiatan"
      subtitle="Momen penerjunan, survei lapangan, audit energi, dan sosialisasi bersama warga Desa Batursari."
    />

    <!-- Wrapper Alpine.js untuk Modal dan Slider -->
    <div
      x-data={`{
        modalOpen: false,
        items: ${serializedGaleri},
        activeIndex: 0,
        intervalId: null,
        openModal(index) {
          this.activeIndex = index;
          this.modalOpen = true;
          this.startAutoSlide();
        },
        closeModal() {
          this.modalOpen = false;
          this.stopAutoSlide();
        },
        nextSlide() {
          this.activeIndex = (this.activeIndex + 1) % this.items.length;
        },
        prevSlide() {
          this.activeIndex = (this.activeIndex - 1 + this.items.length) % this.items.length;
        },
        goToSlide(index) {
          this.activeIndex = index;
          this.startAutoSlide(); // Reset timer
        },
        startAutoSlide() {
          this.stopAutoSlide();
          this.intervalId = setInterval(() => {
            this.nextSlide();
          }, 3500);
        },
        stopAutoSlide() {
          if (this.intervalId) {
            clearInterval(this.intervalId);
            this.intervalId = null;
          }
        }
      }`}
      class="relative"
    >
      <!-- Grid Galeri -->
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
        {galeriList.map((foto, index) => (
          <div
            class="flex flex-col justify-between rounded-2xl overflow-hidden border border-neutral-200 bg-white group hover:shadow-lg transition-all duration-300"
            data-reveal
          >
            <!-- Image Wrapper -->
            <button
              type="button"
              class="w-full overflow-hidden aspect-[4/3] block relative cursor-zoom-in"
              x-on:click={`openModal(${index})`}
            >
              <img
                src={foto.src}
                alt={foto.alt}
                loading="lazy"
                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
              />
              <div class="absolute inset-0 bg-black/20 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                <span class="bg-white/90 backdrop-blur-sm text-neutral-800 text-xs font-semibold px-3 py-2 rounded-full shadow-md flex items-center gap-1.5">
                  <i class="fas fa-search-plus"></i> Lihat Detail
                </span>
              </div>
            </button>

            <!-- Card Info -->
            <div class="p-5 flex flex-col flex-grow justify-between">
              <div>
                {foto.caption && (
                  <p class="text-sm text-neutral-700 leading-relaxed line-clamp-3">
                    {foto.caption}
                  </p>
                )}
              </div>
              <button
                type="button"
                class="mt-4 text-xs font-semibold text-primary-700 hover:text-primary-800 flex items-center gap-1 transition-colors self-start"
                x-on:click={`openModal(${index})`}
              >
                Detail Selengkapnya <i class="fas fa-chevron-right text-[10px]"></i>
              </button>
            </div>
          </div>
        ))}
      </div>

      <!-- Modal Slider -->
      <template x-teleport="body">
        <div
          x-show="modalOpen"
          class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/90 backdrop-blur-md"
          x-transition:enter="transition ease-out duration-300"
          x-transition:enter-start="opacity-0"
          x-transition:enter-end="opacity-100"
          x-transition:leave="transition ease-in duration-200"
          x-transition:leave-start="opacity-100"
          x-transition:leave-end="opacity-0"
          x-on:keydown.escape.window="closeModal()"
          x-cloak
        >
          <!-- Tombol Close -->
          <button
            type="button"
            class="absolute top-6 right-6 text-white/75 hover:text-white text-2xl z-50 p-2 focus:outline-none transition-colors"
            x-on:click="closeModal()"
            aria-label="Tutup Galeri"
          >
            <i class="fas fa-times"></i>
          </button>

          <!-- Main Container -->
          <div 
            class="w-full max-w-4xl flex flex-col items-center gap-6 mt-8"
            x-on:mouseenter="stopAutoSlide()"
            x-on:mouseleave="startAutoSlide()"
          >
            <!-- Slider Image + Arrows Container -->
            <div class="relative w-full aspect-[16/10] sm:aspect-[16/9] max-h-[50vh] sm:max-h-[60vh] bg-neutral-950 rounded-2xl overflow-hidden shadow-2xl flex items-center justify-center border border-white/10">
              
              <!-- Image Slider -->
              <template x-for="(item, idx) in items" :key="item.id">
                <img
                  x-show="activeIndex === idx"
                  :src="item.src"
                  :alt="item.alt"
                  class="absolute inset-0 w-full h-full object-contain p-2"
                  x-transition:enter="transition ease-out duration-500"
                  x-transition:enter-start="opacity-0 scale-95"
                  x-transition:enter-end="opacity-100 scale-100"
                  x-transition:leave="transition ease-in duration-300"
                  x-transition:leave-start="opacity-100 scale-100"
                  x-transition:leave-end="opacity-0 scale-95"
                />
              </template>

              <!-- Arrow Left -->
              <button
                type="button"
                class="absolute left-4 w-11 h-11 rounded-full bg-white/10 hover:bg-white/20 backdrop-blur-sm text-white flex items-center justify-center transition-colors focus:outline-none"
                x-on:click="prevSlide()"
                aria-label="Slide sebelumnya"
              >
                <i class="fas fa-chevron-left"></i>
              </button>

              <!-- Arrow Right -->
              <button
                type="button"
                class="absolute right-4 w-11 h-11 rounded-full bg-white/10 hover:bg-white/20 backdrop-blur-sm text-white flex items-center justify-center transition-colors focus:outline-none"
                x-on:click="nextSlide()"
                aria-label="Slide berikutnya"
              >
                <i class="fas fa-chevron-right"></i>
              </button>
            </div>

            <!-- Active slide caption & alt info -->
            <div class="w-full text-center text-white max-w-3xl px-6">
              <template x-for="(item, idx) in items" :key="item.id">
                <div x-show="activeIndex === idx" class="space-y-2">
                  <h4 class="text-lg sm:text-xl font-bold tracking-tight text-white" x-text="item.alt"></h4>
                  <p class="text-sm sm:text-base text-neutral-300 leading-relaxed" x-text="item.caption"></p>
                </div>
              </template>
            </div>

            <!-- Dots Indicators -->
            <div class="flex gap-2">
              <template x-for="(item, idx) in items" :key="item.id">
                <button
                  type="button"
                  class="w-2.5 h-2.5 rounded-full transition-all duration-300 focus:outline-none"
                  :class="activeIndex === idx ? 'bg-primary-500 scale-125' : 'bg-white/30 hover:bg-white/50'"
                  x-on:click="goToSlide(idx)"
                  :aria-label="'Pergi ke slide ' + (idx + 1)"
                ></button>
              </template>
            </div>
          </div>
        </div>
      </template>
    </div>
  </div>
</section>
