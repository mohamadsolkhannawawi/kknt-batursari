---
import { Image } from "astro:assets";
import Button from "../ui/Button.astro";
import { navigation, navbarCta } from "../../data/navigation";
import logoKkn from "../../assets/images/logo-kkn.png";

const activeItems = navigation.filter((item) => item.enabled);
---

<header
  x-data="{ mobileOpen: false }"
  class="fixed top-6 left-1/2 -translate-x-1/2 z-50 w-[92%] max-w-4xl bg-white/90 backdrop-blur-md border border-neutral-100 shadow-md rounded-full px-5 md:px-6 transition-all"
>
  <div class="flex items-center justify-between h-14 md:h-16 relative">
    <!-- Logo -->
    <a href="#beranda" class="flex items-center gap-2 shrink-0">
      <Image
        src={logoKkn}
        alt="Logo KKN-Tematik 141 Universitas Diponegoro Desa Batursari"
        width={40}
        height={40}
        class="w-8 h-8 md:w-9 md:h-9 rounded-full object-cover"
      />
      <span class="font-heading font-semibold text-sm md:text-base text-primary-900 leading-tight">
        KKN-T 141<br class="hidden sm:block" /> Batursari
      </span>
    </a>

    <!-- Menu desktop -->
    <nav
      aria-label="Menu utama"
      class="hidden lg:flex items-center gap-1 absolute left-1/2 -translate-x-1/2"
    >
      {activeItems.map((item) => (
        item.children ? (
          <div class="relative group">
            <button class="flex items-center gap-1 text-sm font-medium text-neutral-600 hover:text-primary-600 px-4 py-2 rounded-full hover:bg-neutral-50 transition-all">
              {item.label}
              <svg class="w-4 h-4 text-neutral-400 group-hover:text-primary-600 transition-transform duration-300 group-hover:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="absolute top-full left-1/2 -translate-x-1/2 pt-4 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform translate-y-2 group-hover:translate-y-0 z-50">
              <div class="bg-white border border-neutral-100 shadow-xl rounded-2xl py-2 min-w-[200px] flex flex-col relative">
                <!-- Segitiga penunjuk atas -->
                <div class="absolute -top-1.5 left-1/2 -translate-x-1/2 w-3 h-3 bg-white border-t border-l border-neutral-100 rotate-45"></div>
                {item.children.filter(child => child.enabled).map((child) => (
                  <a href={child.href} class="text-sm font-medium text-neutral-600 hover:text-primary-600 hover:bg-primary-50 px-5 py-2.5 transition-colors relative z-10">
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        ) : (
          <a
            href={item.href}
            class="text-sm font-medium text-neutral-600 hover:text-primary-600 px-4 py-2 rounded-full hover:bg-neutral-50 transition-all"
          >
            {item.label}
          </a>
        )
      ))}
    </nav>

    <!-- CTA desktop -->
    <div class="hidden lg:block shrink-0">
      <Button href={navbarCta.href} variant="primary" class="rounded-full shadow-md shadow-primary-500/20 hover:shadow-lg hover:shadow-primary-500/30 text-sm px-5 py-2">{navbarCta.label}</Button>
    </div>

    <!-- Hamburger mobile -->
    <button
      type="button"
      class="lg:hidden inline-flex items-center justify-center w-10 h-10 rounded-full text-primary-900 hover:bg-neutral-50 focus-visible:ring-2 focus-visible:ring-primary-500 transition-colors"
      x-on:click="mobileOpen = !mobileOpen"
      x-bind:aria-expanded="mobileOpen"
      aria-controls="menu-mobile"
      aria-label="Buka menu navigasi"
    >
      <svg x-show="!mobileOpen" viewBox="0 0 24 24" class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg x-show="mobileOpen" viewBox="0 0 24 24" class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true" x-cloak>
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
      </svg>
    </button>

    <!-- Menu mobile (dropdown) -->
    <nav
      id="menu-mobile"
      aria-label="Menu navigasi mobile"
      x-show="mobileOpen"
      @click.away="mobileOpen = false"
      x-cloak
      x-transition:enter="transition ease-out duration-200"
      x-transition:enter-start="opacity-0 -translate-y-4 scale-95"
      x-transition:enter-end="opacity-100 translate-y-0 scale-100"
      x-transition:leave="transition ease-in duration-150"
      x-transition:leave-start="opacity-100 translate-y-0 scale-100"
      x-transition:leave-end="opacity-0 -translate-y-4 scale-95"
      class="lg:hidden absolute top-full left-0 right-0 mt-4 bg-white border border-neutral-100 shadow-xl rounded-2xl overflow-hidden origin-top"
    >
      <div class="p-4 flex flex-col gap-1 max-h-[70vh] overflow-y-auto">
        {activeItems.map((item) => (
          item.children ? (
            <div x-data="{ open: false }" class="flex flex-col">
              <button @click="open = !open" class="flex items-center justify-between text-sm font-medium text-neutral-900 py-3 px-4 rounded-xl hover:bg-neutral-50 transition-colors">
                {item.label}
                <svg :class="{'rotate-180': open}" class="w-4 h-4 text-neutral-400 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
              <div x-show="open" x-collapse class="flex flex-col pl-4 border-l-2 border-neutral-100 ml-4 mt-1 space-y-1">
                {item.children.filter(child => child.enabled).map((child) => (
                  <a href={child.href} @click="mobileOpen = false" class="text-sm font-medium text-neutral-600 hover:text-primary-700 py-2.5 px-4 rounded-xl hover:bg-neutral-50 transition-colors">
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          ) : (
            <a
              href={item.href}
              @click="mobileOpen = false"
              class="text-sm font-medium text-neutral-900 hover:text-primary-700 py-3 px-4 rounded-xl hover:bg-neutral-50 transition-colors"
            >
              {item.label}
            </a>
          )
        ))}
        <div class="pt-4 mt-2 border-t border-neutral-100">
          <Button href={navbarCta.href} variant="primary" class="w-full justify-center rounded-xl py-3">
            {navbarCta.label}
          </Button>
        </div>
      </div>
    </nav>
  </div>
</header>
